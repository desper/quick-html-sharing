{
  "name": "quick-html-share-mcp",
  "version": "0.1.0",
  "description": "MCP server for quick-html-sharing — upload HTML and get a shareable URL from any MCP client (Claude Desktop, Cursor, Codex CLI, etc).",
  "keywords": ["mcp", "model-context-protocol", "html", "sharing", "claude", "cursor"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "quick-html-share-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
