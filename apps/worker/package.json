{
  "name": "@qhs/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --env api",
    "deploy:api": "wrangler deploy --env api",
    "deploy:share": "wrangler deploy --env share",
    "deploy": "bun run deploy:api && bun run deploy:share",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute quick-html-sharing --local --env api --file=db/schema.sql",
    "db:apply:remote": "wrangler d1 execute quick-html-sharing --remote --env api --file=db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "@qhs/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20250101.0",
    "vitest": "2.1.9",
    "wrangler": "^3.99.0"
  }
}
