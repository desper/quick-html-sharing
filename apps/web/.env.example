# Copy to .env.production for build-time injection.
# Astro inlines this into the static bundle at build time.

# The API worker URL after `wrangler deploy --env api`.
# Format: https://qhs-api.<your-cf-account>.workers.dev/api
PUBLIC_API_BASE=https://qhs-api.<TBD-CF-ACCOUNT>.workers.dev/api

# The share worker URL — used to generate Open Share links from the dashboard.
PUBLIC_SHARE_BASE=https://qhs-share.<TBD-CF-ACCOUNT>.workers.dev
