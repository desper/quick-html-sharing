# Copy to .env.production for build-time injection.
# Astro inlines this into the static bundle at build time.

# Hosted endpoints (canonical, post qhs.fyi migration). For a separate
# fork / staging deploy, point these at your own *.workers.dev URLs.
PUBLIC_API_BASE=https://api.qhs.fyi/api
PUBLIC_SHARE_BASE=https://s.qhs.fyi
